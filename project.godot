; Engine configuration file.
; It's best edited using the editor UI and not directly,
; but it can also be edited with a plain text editor.

[application]

config/name="Captain's Ledger"
config/description="Crew system prototype for Gravity Nexus"
run/main_scene="res://scenes/ui/main_menu.tscn"
config/features=PackedStringArray("4.5")

[autoload]

EventBus="*res://scripts/core/event_bus.gd"
DatabaseManager="*res://scripts/core/database_manager.gd"
GameManager="*res://scripts/core/game_manager.gd"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/size/resizable=true
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[gui]

theme/custom="res://resources/themes/main_theme.tres"

[rendering]

renderer/rendering_method="gl_compatibility"
